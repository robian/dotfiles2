#!/bin/sh
set -eu

PROGRAM=${0##*/}
TOOL_ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
PROJECT_ROOT=$(pwd -P)
. "$TOOL_ROOT/lib/repo-config.sh"

DEFAULT_WORKSPACE_SIZE=10GiB

SOURCE_TEMPLATE_FILE=$TOOL_ROOT/tools/project-vm/lima.yaml
SETUP_SCRIPT=$TOOL_ROOT/tools/project-vm/setup.sh

WORKSPACE_MOUNT=/home/dev/workspace
GUEST_DEFAULT_WORKDIR=/home/dev
GUEST_LOGIN_SHELL=/usr/bin/zsh
GUEST_SETUP_HASH_FILE=/var/lib/project-vm/setup-hash
SECRET_ENV_IDENTITY_DOCUMENT=project-vm-age-identity

usage() {
  cat <<EOF
Usage:
  $PROGRAM start [--skip-setup]
  $PROGRAM setup
  $PROGRAM shell [--ssh-agent] [--env-file FILE] [--secret-env-file FILE] [-- COMMAND...]
  $PROGRAM secret-env edit FILE
  $PROGRAM stop
  $PROGRAM status
  $PROGRAM delete-vm
  $PROGRAM limactl ARGS...

Examples:
  cd /path/to/project
  $PROGRAM start
  $PROGRAM shell -- git clone https://github.com/example/repo.git
  $PROGRAM shell --env-file .env --secret-env-file .env.age
  $PROGRAM secret-env edit .env.age
EOF
}

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

need_limactl() {
  command -v limactl >/dev/null 2>&1 || die "limactl is required but was not found in PATH"
}

need_op() {
  command -v op >/dev/null 2>&1 || die "op is required but was not found in PATH"
}

need_rage() {
  command -v rage >/dev/null 2>&1 || die "rage is required but was not found in PATH"
}

lima() {
  need_limactl
  limactl "$@"
}

ensure_state_dir() {
  :
}

sanitize_basename() {
  name=$(basename "$PROJECT_ROOT" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9][^a-z0-9]*/-/g; s/^-//; s/-$//')
  [ -n "$name" ] || name=project
  printf '%s\n' "$name" | cut -c 1-32
}

project_hash() {
  if command -v shasum >/dev/null 2>&1; then
    printf '%s' "$PROJECT_ROOT" | shasum -a 256 | cut -c 1-6
  elif command -v sha256sum >/dev/null 2>&1; then
    printf '%s' "$PROJECT_ROOT" | sha256sum | cut -c 1-6
  else
    printf '%s' "$PROJECT_ROOT" | cksum | cut -d' ' -f1 | cut -c 1-6
  fi
}

create_instance_name() {
  printf '%s-%s\n' "$(sanitize_basename)" "$(project_hash)"
}

shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

shell_command() {
  command_line=
  for arg; do
    quoted=$(shell_quote "$arg")
    if [ -n "$command_line" ]; then
      command_line="$command_line $quoted"
    else
      command_line=$quoted
    fi
  done
  printf '%s\n' "$command_line"
}

shell_eval_command() {
  if [ "$#" -eq 1 ]; then
    printf '%s\n' "$1"
  else
    shell_command "$@"
  fi
}

trim_line() {
  printf '%s\n' "$1" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

valid_env_name() {
  expr "$1" : '[A-Za-z_][A-Za-z0-9_]*$' >/dev/null 2>&1
}

append_env_file_assignments() {
  env_file=$1
  assignments_file=$2

  [ -f "$env_file" ] || die "env file does not exist: $env_file"

  line_number=0
  while IFS= read -r raw_line || [ -n "$raw_line" ]; do
    line_number=$((line_number + 1))
    line=$(trim_line "$raw_line")

    case "$line" in
    "" | \#*) continue ;;
    export\ *) line=$(trim_line "${line#export }") ;;
    esac

    case "$line" in
    *=*) ;;
    *) die "unsupported env line in $env_file:$line_number" ;;
    esac

    key=$(trim_line "${line%%=*}")
    value=$(trim_line "${line#*=}")

    valid_env_name "$key" || die "invalid env variable name in $env_file:$line_number: $key"

    case "$value" in
    \"*\")
      case "$value" in
      *\") value=${value#\"}; value=${value%\"} ;;
      *) die "unterminated double-quoted value in $env_file:$line_number" ;;
      esac
      ;;
    \'*\')
      case "$value" in
      *\') value=${value#\'}; value=${value%\'} ;;
      *) die "unterminated single-quoted value in $env_file:$line_number" ;;
      esac
      ;;
    esac

    printf '%s=%s\n' "$key" "$(shell_quote "$value")" >>"$assignments_file"
  done <"$env_file"
}

decrypt_secret_env_file() {
  encrypted_file=$1
  output_file=$2

  [ -f "$encrypted_file" ] || die "secret env file does not exist: $encrypted_file"
  need_op
  need_rage

  op document get "$SECRET_ENV_IDENTITY_DOCUMENT" | rage -d -i /dev/stdin -o "$output_file" "$encrypted_file"
}

append_secret_env_file_assignments() {
  encrypted_file=$1
  assignments_file=$2
  plain_file=$(mktemp "${TMPDIR:-/tmp}/project-vm-secret-env.XXXXXX")

  if decrypt_secret_env_file "$encrypted_file" "$plain_file"; then
    append_env_file_assignments "$plain_file" "$assignments_file"
    rm -f "$plain_file"
  else
    rm -f "$plain_file"
    return 1
  fi
}

secret_env_recipient() {
  identity_file=$1

  recipient=$(sed -n 's/^# public key: //p' "$identity_file" | head -n 1)
  [ -n "$recipient" ] || die "could not find public key in 1Password document: $SECRET_ENV_IDENTITY_DOCUMENT"
  printf '%s\n' "$recipient"
}

cmd_secret_env_edit() {
  [ "$#" -eq 1 ] || die "usage: $PROGRAM secret-env edit FILE"

  encrypted_file=$1
  encrypted_dir=$(dirname -- "$encrypted_file")
  encrypted_base=$(basename -- "$encrypted_file")
  [ -d "$encrypted_dir" ] || die "directory does not exist: $encrypted_dir"

  need_op
  need_rage

  identity_file=$(mktemp "${TMPDIR:-/tmp}/project-vm-age-identity.XXXXXX")
  plain_file=$(mktemp "${TMPDIR:-/tmp}/project-vm-secret-env.XXXXXX")
  encrypted_tmp=$(mktemp "$encrypted_dir/.$encrypted_base.XXXXXX")
  rm -f "$encrypted_tmp"
  trap 'rm -f "$identity_file" "$plain_file" "$encrypted_tmp"' EXIT HUP INT TERM

  op document get "$SECRET_ENV_IDENTITY_DOCUMENT" >"$identity_file"
  recipient=$(secret_env_recipient "$identity_file")

  if [ -f "$encrypted_file" ]; then
    rage -d -i "$identity_file" -o "$plain_file" "$encrypted_file"
  else
    {
      printf '# Edit project VM secret environment variables below.\n'
      printf '# Example: API_TOKEN=...\n'
    } >"$plain_file"
  fi

  "${EDITOR:-vi}" "$plain_file"
  append_env_file_assignments "$plain_file" /dev/null
  rage -r "$recipient" -o "$encrypted_tmp" "$plain_file"
  mv "$encrypted_tmp" "$encrypted_file"

  rm -f "$identity_file" "$plain_file"
  trap - EXIT HUP INT TERM
  printf 'secret env written: %s\n' "$encrypted_file"
}

cmd_secret_env() {
  subcmd=${1:-}
  [ -n "$subcmd" ] || die "usage: $PROGRAM secret-env edit FILE"
  shift

  case "$subcmd" in
  edit) cmd_secret_env_edit "$@" ;;
  *) die "unknown secret-env command: $subcmd" ;;
  esac
}

env_assignments_command() {
  assignments_file=$1
  command_line=

  [ -s "$assignments_file" ] || return 0

  while IFS= read -r assignment || [ -n "$assignment" ]; do
    if [ -n "$command_line" ]; then
      command_line="$command_line $assignment"
    else
      command_line=$assignment
    fi
  done <"$assignments_file"

  printf '%s\n' "$command_line"
}

guest_shell_remote_command() {
  assignments_file=$1
  shift

  workdir=$(shell_quote "$GUEST_DEFAULT_WORKDIR")
  shell=$(shell_quote "$GUEST_LOGIN_SHELL")
  env_assignments=$(env_assignments_command "$assignments_file")

  if [ -n "$env_assignments" ]; then
    exec_prefix="env $env_assignments "
  else
    exec_prefix=
  fi

  if [ "$#" -gt 0 ]; then
    printf 'cd -- %s && exec %s%s -lic %s\n' \
      "$workdir" \
      "$exec_prefix" \
      "$shell" \
      "$(shell_quote "$(shell_eval_command "$@")")"
  else
    printf 'cd -- %s && exec %s%s -l\n' \
      "$workdir" \
      "$exec_prefix" \
      "$shell"
  fi
}

hash_stream() {
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 | cut -d' ' -f1
  elif command -v sha256sum >/dev/null 2>&1; then
    sha256sum | cut -d' ' -f1
  else
    cksum | cut -d' ' -f1
  fi
}

setup_hash() {
  [ -f "$SETUP_SCRIPT" ] || die "missing setup script: $SETUP_SCRIPT"
  {
    printf 'setup-script:%s\n' "$SETUP_SCRIPT"
    cat "$SETUP_SCRIPT"
    printf '\nrepo-https-url:%s\n' "$REPO_HTTPS_URL"
    printf 'repo-ssh-url:%s\n' "$REPO_SSH_URL"
    printf 'repo-name:%s\n' "$REPO_NAME"
  } | hash_stream
}

resolve_instance() {
  create_instance_name
}

workspace_disk() {
  resolve_instance
}

workspace_disk_mount() {
  printf '/mnt/lima-%s\n' "$(workspace_disk)"
}

instance_status() {
  instance=$1
  lima list "$instance" --format '{{.Status}}' --tty=false 2>/dev/null || true
}

instance_field() {
  instance=$1
  field=$2
  lima list "$instance" --format "{{.$field}}" --tty=false 2>/dev/null || true
}

instance_ssh_config_file() {
  instance=$1
  instance_field "$instance" SSHConfigFile
}

host_identity_agent() {
  agent=${PROJECT_VM_SSH_AUTH_SOCK:-}
  if [ -z "$agent" ]; then
    # TODO: Once the host shell exports the actual agent socket as SSH_AUTH_SOCK,
    # use SSH_AUTH_SOCK directly and remove this compatibility lookup. The current
    # host SSH setup may select 1Password via IdentityAgent while SSH_AUTH_SOCK
    # still points at an empty launchd agent.
    agent=$(ssh -G github.com 2>/dev/null | sed -n 's/^identityagent //p' | head -n 1)
  fi
  if [ -z "$agent" ] || [ "$agent" = "none" ]; then
    agent=${SSH_AUTH_SOCK:-}
  fi
  [ -n "$agent" ] || die "--ssh-agent requires SSH_AUTH_SOCK or PROJECT_VM_SSH_AUTH_SOCK to be set on the host"
  printf '%s\n' "$agent"
}

ssh_agent_shell() {
  instance=$1
  assignments_file=$2
  shift
  shift

  command -v ssh >/dev/null 2>&1 || die "ssh is required but was not found in PATH"
  ssh_config=$(instance_ssh_config_file "$instance")
  [ -n "$ssh_config" ] || die "could not find Lima SSH config for instance: $instance"
  [ -f "$ssh_config" ] || die "Lima SSH config does not exist: $ssh_config"

  agent=$(host_identity_agent)
  host=lima-$instance
  remote=$(guest_shell_remote_command "$assignments_file" "$@")
  rm -f "$assignments_file"
  trap - EXIT HUP INT TERM

  if [ "$#" -gt 0 ]; then
    exec env SSH_AUTH_SOCK="$agent" ssh \
      -F "$ssh_config" \
      -A \
      -o ForwardAgent=yes \
      -o ControlMaster=no \
      -o ControlPath=none \
      "$host" \
      "$remote"
  else
    exec env SSH_AUTH_SOCK="$agent" ssh \
      -F "$ssh_config" \
      -A \
      -o ForwardAgent=yes \
      -o ControlMaster=no \
      -o ControlPath=none \
      -t \
      "$host" \
      "$remote"
  fi
}

ensure_instance_running() {
  instance=$1
  status=$(instance_status "$instance")

  case "$status" in
  Running) return 0 ;;
  "") die "VM instance does not exist; run '$PROGRAM start' first" ;;
  *) die "VM instance is $status; run '$PROGRAM start' first" ;;
  esac
}

render_template() {
  tmp=$(mktemp "${TMPDIR:-/tmp}/project-vm-lima.XXXXXX.yaml")
  [ -f "$SOURCE_TEMPLATE_FILE" ] || die "missing Lima source template: $SOURCE_TEMPLATE_FILE"
  workspace_disk=$(workspace_disk)

  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
    *'{{WORKSPACE_DISK}}'* | *'{{WORKSPACE_MOUNT}}'*)
      while :; do
        case "$line" in
        *'{{WORKSPACE_DISK}}'*)
          line=${line%%'{{WORKSPACE_DISK}}'*}$workspace_disk${line#*'{{WORKSPACE_DISK}}'}
          ;;
        *'{{WORKSPACE_MOUNT}}'*)
          line=${line%%'{{WORKSPACE_MOUNT}}'*}$WORKSPACE_MOUNT${line#*'{{WORKSPACE_MOUNT}}'}
          ;;
        *) break ;;
        esac
      done
      printf '%s\n' "$line" >>"$tmp"
      ;;
    *)
      printf '%s\n' "$line" >>"$tmp"
      ;;
    esac
  done <"$SOURCE_TEMPLATE_FILE"

  printf '%s\n' "$tmp"
}

instance_exists() {
  instance=$1
  [ -n "$(instance_status "$instance")" ]
}

workspace_disk_exists() {
  disk=$1
  lima disk ls 2>/dev/null | awk 'NR > 1 { print $1 }' | grep -Fx "$disk" >/dev/null 2>&1
}

ensure_workspace_disk() {
  disk=$(workspace_disk)
  if workspace_disk_exists "$disk"; then
    return
  fi

  lima disk create "$disk" --size "$DEFAULT_WORKSPACE_SIZE" --format raw --tty=false
}

ensure_guest_workspace() {
  instance=$1
  disk_mount=$(workspace_disk_mount)
  lima shell --workdir /home/dev "$instance" sudo sh -c "set -eu
disk_mount=$(shell_quote "$disk_mount")
workspace_mount=$(shell_quote "$WORKSPACE_MOUNT")
install -d -m 755 /home/dev
if ! mountpoint -q \"\$disk_mount\"; then
  echo \"workspace disk is not mounted: \$disk_mount\" >&2
  exit 1
fi
chown dev:dev \"\$disk_mount\"
if [ -e \"\$workspace_mount\" ] && [ ! -L \"\$workspace_mount\" ]; then
  echo \"workspace path exists and is not a symlink: \$workspace_mount\" >&2
  exit 1
fi
ln -sfn \"\$disk_mount\" \"\$workspace_mount\""
}

ensure_initialized() {
  [ "$#" -eq 0 ] || die "internal initialization does not accept arguments"

  ensure_state_dir
  ensure_workspace_disk
  instance=$(resolve_instance)

  if instance_exists "$instance"; then
    return
  fi

  template=$(render_template)
  if lima create --name "$instance" "$template" --tty=false; then
    rm -f "$template"
  else
    printf 'kept failed Lima template for debugging: %s\n' "$template" >&2
    exit 1
  fi
}

start_instance() {
  instance=$1
  status=$(instance_status "$instance")

  case "$status" in
  Running) printf 'VM instance already running: %s\n' "$instance" ;;
  "") die "VM instance does not exist; run '$PROGRAM start' first" ;;
  *) lima start "$instance" --tty=false ;;
  esac
}

run_setup_script() {
  instance=$1
  [ -f "$SETUP_SCRIPT" ] || die "missing setup script: $SETUP_SCRIPT"

  {
    printf 'REPO_HTTPS_URL=%s\n' "$(shell_quote "$REPO_HTTPS_URL")"
    printf 'REPO_SSH_URL=%s\n' "$(shell_quote "$REPO_SSH_URL")"
    printf 'REPO_NAME=%s\n' "$(shell_quote "$REPO_NAME")"
    cat "$SETUP_SCRIPT"
  } | lima shell --workdir /home/dev "$instance" sudo sh -s
}

guest_setup_hash() {
  instance=$1
  lima shell --workdir /home/dev "$instance" sudo sh -c "cat '$GUEST_SETUP_HASH_FILE' 2>/dev/null || true"
}

write_guest_setup_hash() {
  instance=$1
  hash=$2
  lima shell --workdir /home/dev "$instance" sudo sh -c "install -d -m 755 /var/lib/project-vm && printf '%s\n' $(shell_quote "$hash") > '$GUEST_SETUP_HASH_FILE'"
}

setup_state() {
  instance=$1
  current_hash=$(setup_hash)
  stored_hash=$(guest_setup_hash "$instance")

  if [ -z "$stored_hash" ]; then
    printf 'missing\n'
  elif [ "$stored_hash" = "$current_hash" ]; then
    printf 'complete\n'
  else
    printf 'changed\n'
  fi
}

install_host_terminfo() {
  instance=$1
  term=${TERM:-xterm-ghostty}
  remote="/tmp/project-vm-terminfo.$$"
  tmp=$(mktemp "${TMPDIR:-/tmp}/project-vm-terminfo.XXXXXX")

  if ! command -v infocmp >/dev/null 2>&1; then
    rm -f "$tmp"
    printf 'warning: infocmp not found on host; skipping terminfo install\n' >&2
    return 0
  fi

  if ! infocmp -x "$term" >"$tmp"; then
    rm -f "$tmp"
    printf 'warning: terminfo not found on host for TERM=%s\n' "$term" >&2
    return 0
  fi

  if ! lima copy "$tmp" "$instance:$remote"; then
    rm -f "$tmp"
    return 1
  fi
  rm -f "$tmp"

  lima shell --workdir /home/dev "$instance" sh -lc '
		set -eu
		mkdir -p "$HOME/.terminfo"
		log=$(mktemp)
		if ! tic -x -o "$HOME/.terminfo" "$1" >"$log" 2>&1; then
			cat "$log" >&2
			rm -f "$log" "$1"
			exit 1
		fi
		grep -v "older tic versions may treat the description field as an alias" "$log" >&2 || true
		rm -f "$log" "$1"
	' sh "$remote"
}

cmd_setup() {
  [ "$#" -eq 0 ] || die "setup does not accept arguments"
  instance=$(resolve_instance)
  instance_exists "$instance" || die "VM instance does not exist; run '$PROGRAM start' first"
  ensure_instance_running "$instance"
  ensure_guest_workspace "$instance"

  run_setup_script "$instance"
  install_host_terminfo "$instance"
  write_guest_setup_hash "$instance" "$(setup_hash)"
  printf 'setup complete: %s\n' "$GUEST_SETUP_HASH_FILE"
}

cmd_start() {
  skip_setup=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
    --skip-setup)
      skip_setup=1
      shift
      ;;
    *)
      die "unexpected start argument: $1"
      ;;
    esac
  done

  ensure_initialized
  instance=$(resolve_instance)
  start_instance "$instance"
  ensure_guest_workspace "$instance"

  if [ "$skip_setup" -eq 0 ]; then
    state=$(setup_state "$instance")
    case "$state" in
    missing)
      cmd_setup
      ;;
    changed)
      printf 'warning: VM setup hash differs from current setup script; not running setup automatically\n' >&2
      ;;
    esac
  fi
}

cmd_shell() {
  forward_agent=0
  assignments_file=$(mktemp "${TMPDIR:-/tmp}/project-vm-env.XXXXXX")
  trap 'rm -f "$assignments_file"' EXIT HUP INT TERM

  while [ "$#" -gt 0 ]; do
    case "$1" in
    --ssh-agent)
      forward_agent=1
      shift
      ;;
    --env-file)
      shift
      [ "$#" -gt 0 ] || die "--env-file requires a file argument"
      append_env_file_assignments "$1" "$assignments_file"
      shift
      ;;
    --secret-env-file)
      shift
      [ "$#" -gt 0 ] || die "--secret-env-file requires a file argument"
      append_secret_env_file_assignments "$1" "$assignments_file"
      shift
      ;;
    --)
      shift
      break
      ;;
    -*)
      die "unexpected shell argument: $1"
      ;;
    *)
      break
      ;;
    esac
  done

  instance=$(resolve_instance)
  instance_exists "$instance" || die "VM instance does not exist; run '$PROGRAM start' first"
  ensure_instance_running "$instance"
  ensure_guest_workspace "$instance"

  if [ "$forward_agent" -eq 1 ]; then
    ssh_agent_shell "$instance" "$assignments_file" "$@"
  else
    remote=$(guest_shell_remote_command "$assignments_file" "$@")
    rm -f "$assignments_file"
    trap - EXIT HUP INT TERM
    exec limactl shell --workdir /home/dev "$instance" sh -lc "$remote"
  fi
}

cmd_stop() {
  [ "$#" -eq 0 ] || die "stop does not accept arguments"
  instance=$(resolve_instance)
  instance_exists "$instance" || die "VM instance does not exist"
  lima stop "$instance"
}

cmd_status() {
  [ "$#" -eq 0 ] || die "status does not accept arguments"
  ensure_state_dir
  instance=$(resolve_instance)

  printf 'project root: %s\n' "$PROJECT_ROOT"
  printf 'instance: %s\n' "$instance"
  printf 'workspace disk: %s\n' "$(workspace_disk)"
  printf 'workspace disk mount: %s\n' "$(workspace_disk_mount)"
  printf 'workspace mount: %s\n' "$WORKSPACE_MOUNT"
  if workspace_disk_exists "$(workspace_disk)"; then
    printf 'workspace disk exists: yes\n'
  else
    printf 'workspace disk exists: no\n'
  fi

  if instance_exists "$instance"; then
    status=$(instance_status "$instance")
    if [ "$status" = "Running" ]; then
      printf 'setup: %s\n' "$(setup_state "$instance")"
    else
      printf 'setup: unknown (VM is %s)\n' "$status"
    fi
    printf '\n'
    lima list "$instance"
  else
    printf 'setup: missing\n'
    printf '\n'
    printf 'VM instance: missing\n'
  fi
}

cmd_delete_vm() {
  [ "$#" -eq 0 ] || die "delete-vm does not accept arguments"
  instance=$(resolve_instance)
  instance_exists "$instance" || die "VM instance does not exist"
  lima delete "$instance"
  printf 'workspace disk preserved: %s\n' "$(workspace_disk)"
}

main() {
  cmd=${1:-}
  [ -n "$cmd" ] || {
    usage
    exit 2
  }
  shift

  case "$cmd" in
  start) cmd_start "$@" ;;
  setup) cmd_setup "$@" ;;
  shell) cmd_shell "$@" ;;
  secret-env) cmd_secret_env "$@" ;;
  stop) cmd_stop "$@" ;;
  status) cmd_status "$@" ;;
  delete-vm) cmd_delete_vm "$@" ;;
  limactl)
    ensure_state_dir
    lima "$@"
    ;;
  -h | --help | help) usage ;;
  *) die "unknown command: $cmd" ;;
  esac
}

main "$@"
