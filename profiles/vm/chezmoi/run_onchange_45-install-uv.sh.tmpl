#!/usr/bin/env sh
set -eu

step() {
  printf '\033[1;36m==> %s\033[0m\n' "$*" >&2
}

uv_version="{{ .vm_versions.uv }}"
uv_dir="$HOME/.local/opt/uv"
uv_marker="$uv_dir/.vm-version"

case "$(uname -m)" in
  aarch64) target=aarch64-unknown-linux-gnu ;;
  x86_64) target=x86_64-unknown-linux-gnu ;;
  *)
    echo "unsupported uv architecture: $(uname -m)" >&2
    exit 1
    ;;
esac

if [ -x "$uv_dir/uv" ] && [ -x "$uv_dir/uvx" ] && [ -f "$uv_marker" ] && [ "$(cat "$uv_marker")" = "$uv_version" ]; then
  exit 0
fi

step "Installing uv $uv_version"

archive="$(mktemp)"
extract_dir="$(mktemp -d)"
log="$(mktemp)"
if ! {
  curl -fsSL "https://releases.astral.sh/github/uv/releases/download/${uv_version}/uv-${target}.tar.gz" -o "$archive"
  tar -C "$extract_dir" --strip-components=1 -xzf "$archive"
  printf '%s\n' "$uv_version" >"$extract_dir/.vm-version"

  mkdir -p "$HOME/.local/opt" "$HOME/.local/bin"
  rm -rf "$uv_dir"
  mv "$extract_dir" "$uv_dir"
  ln -sf "$uv_dir/uv" "$HOME/.local/bin/uv"
  ln -sf "$uv_dir/uvx" "$HOME/.local/bin/uvx"
} >"$log" 2>&1; then
  cat "$log" >&2
  rm -rf "$extract_dir"
  rm -f "$archive" "$log"
  exit 1
fi

rm -f "$archive" "$log"
