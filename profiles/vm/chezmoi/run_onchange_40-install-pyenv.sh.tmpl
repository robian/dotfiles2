#!/usr/bin/env sh
set -eu

step() {
  printf '\033[1;36m==> %s\033[0m\n' "$*" >&2
}

pyenv_root="${PYENV_ROOT:-$HOME/.pyenv}"
pyenv_version="{{ .vm_versions.pyenv }}"

if [ -d "$pyenv_root/.git" ]; then
  step "Updating pyenv to $pyenv_version"

  log="$(mktemp)"
  if ! {
    git -C "$pyenv_root" fetch --quiet --depth 1 origin "refs/tags/$pyenv_version:refs/tags/$pyenv_version"
    git -C "$pyenv_root" -c advice.detachedHead=false checkout --quiet "$pyenv_version"
  } >"$log" 2>&1; then
    cat "$log" >&2
    rm -f "$log"
    exit 1
  fi
  rm -f "$log"
  exit 0
fi

if [ -e "$pyenv_root" ]; then
  echo "pyenv path exists but is not a git checkout: $pyenv_root" >&2
  exit 1
fi

step "Installing pyenv $pyenv_version"

mkdir -p "$(dirname -- "$pyenv_root")"
log="$(mktemp)"
if ! git -c advice.detachedHead=false clone \
  --quiet \
  --branch "$pyenv_version" \
  --depth 1 \
  https://github.com/pyenv/pyenv.git \
  "$pyenv_root" >"$log" 2>&1; then
  cat "$log" >&2
  rm -f "$log"
  exit 1
fi
rm -f "$log"
