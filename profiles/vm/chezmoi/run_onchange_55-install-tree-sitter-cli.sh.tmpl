#!/usr/bin/env sh
set -eu

tree_sitter_cli_version="{{ .vm_versions.tree_sitter_cli }}"

step() {
  printf '\033[1;36m==> %s\033[0m\n' "$*" >&2
}

export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"

if [ ! -s "$NVM_DIR/nvm.sh" ]; then
  echo "nvm is not installed at $NVM_DIR" >&2
  exit 1
fi

. "$NVM_DIR/nvm.sh"

step "Installing tree-sitter-cli $tree_sitter_cli_version"

log="$(mktemp)"
if ! {
  nvm use default
  npm install -g --no-audit --no-fund --loglevel=error "tree-sitter-cli@${tree_sitter_cli_version}"
} >"$log" 2>&1; then
  cat "$log" >&2
  rm -f "$log"
  exit 1
fi
rm -f "$log"

mkdir -p "$HOME/.local/bin"
cat >"$HOME/.local/bin/tree-sitter" <<'TREE_SITTER'
#!/usr/bin/env bash
set -euo pipefail

export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"

if [ ! -s "$NVM_DIR/nvm.sh" ]; then
  echo "tree-sitter wrapper: nvm is not installed at $NVM_DIR" >&2
  exit 127
fi

. "$NVM_DIR/nvm.sh"

node_bin="$(dirname "$(nvm which default)")"
exec "$node_bin/tree-sitter" "$@"
TREE_SITTER

chmod 0755 "$HOME/.local/bin/tree-sitter"
